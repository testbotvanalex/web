      "destination": "/public/prijzen"
    },
    {
      "source": "/whatsapp-bots",
      "destination": "/public/whatsapp-bots"
    },
    {
      "source": "/cases",
      "destination": "/public/cases"
    },
    {
      "source": "/vergelijking",
      "destination": "/public/vergelijking"
    },
    {
      "source": "/faq",
      "destination": "/public/faq"
    },
    {
      "source": "/contact",
      "destination": "/public/contact"
