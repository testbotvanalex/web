{
  "buildCommand": null,
  "outputDirectory": ".",
  "framework": null,
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/start",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/citech",         "destination": "/public/citech" },
    { "source": "/citech/",        "destination": "/public/citech" },
    { "source": "/citecht",        "destination": "/public/citech" },
    { "source": "/citecht/",       "destination": "/public/citech" },
    { "source": "/auth/:path*",     "destination": "https://botmatic.be/auth/:path*" },
    { "source": "/api/:path*",      "destination": "https://botmatic.be/api/:path*" },
    { "source": "/webhook/:path*",  "destination": "https://botmatic.be/webhook/:path*" },
    { "source": "/admin/:path*",    "destination": "https://botmatic.be/admin/:path*" },
    { "source": "/admin",           "destination": "https://botmatic.be/admin" },
    { "source": "/client/:path*",   "destination": "https://botmatic.be/client/:path*" },
    { "source": "/client",          "destination": "https://botmatic.be/client" },
    { "source": "/inbox",           "destination": "https://botmatic.be/inbox" },
    { "source": "/dashboard",       "destination": "https://botmatic.be/dashboard" },
    { "source": "/analytics",       "destination": "https://botmatic.be/analytics" },
    { "source": "/bots",            "destination": "https://botmatic.be/bots" },
    { "source": "/bot",             "destination": "https://botmatic.be/bot" },
    { "source": "/constructor",     "destination": "https://botmatic.be/constructor" },
    { "source": "/train",           "destination": "https://botmatic.be/train" },
    { "source": "/start",           "destination": "https://botmatic.be/start" }
  ]
}
