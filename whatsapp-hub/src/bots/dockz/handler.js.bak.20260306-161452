export async function handleIncoming(from, textArg) {
    try {
        const text = (textArg || "").trim();
        const cleanBox = text.toLowerCase();

        const user = await getUser(from);
        let step = user ? user.step : null;

        // Force-generate on confirm button title (WhatsApp sometimes sends title, not id)
        const rawLower = String(text || "").toLowerCase();
        if (step === "doc_confirm" && (cleanBox === "confirm_yes" || cleanBox === "gendoc" || rawLower.includes("сгенер"))) {
            await generateDoc(from);
            return;
        }

        console.log(`📠 Incoming from ${from}: "${text}" (Step: ${step})`);

        // Global reset
        if (cleanBox === "/reset" || cleanBox === "reset" || cleanBox === "start" || cleanBox === "старт") {
            console.log(`🔄 RESET triggered for ${from}`);
            try {
                const user = await getUser(from);
                const name = user?.data ? JSON.parse(user.data).profile_name || "" : "";
                await sendTelegramMessage(`✨ <b>НОВЫЙ ВХОД</b>\n👤 +${from} ${name ? `(${name})` : ""}`);
            } catch (e) { }

            await resetUser(from);
            await initUser(from); // Re-init to ensure session exists
            await sendGreetingStart(from);
            await setStep(from, "ux_greeting");
            return;
        }

        // TEST CRASH (Temporary)
        if (cleanBox === "/test_crash" || cleanBox === "test_crash") {
            throw new Error("Тестовая ошибка для проверки Telegram логов! 🧪");
        }
        // New user -> ENTRY
        if (!step) {
            await initUser(from);
            await sendGreetingStart(from);
            await setStep(from, "ux_greeting");
            return;
        }

        // UX Flow Step 1: Greeting
        if (cleanBox === "ux_start") {
            await setData(from, "doc_key", ONLY_DOC_KEY);
            await setStep(from, "doc_info");
            await sendDocInfo(from, ONLY_DOC_KEY);
            return;
        }
        if (cleanBox === "ux_how") {
