async function askDocQuestion(from) {
    const state = await getUser(from);
    const d = state?.data || {};
    const doc = getDoc(d.doc_key);
    if (!doc) return goToMenuPreserveLang(from);

    const idx = Number(d.doc_index || 0);
    const field = doc.fields[idx];
    if (!field) return sendDocConfirm(from);

    if (field === "notary") {
        await setData(from, "doc_waiting_notary", true);
        await setStep(from, "s2_notary_choice");
        const t = await getT(from);
        await sendInteractiveButtons(from, t.notary_choice_ask, [
            { id: "s2_choice_search", title: t.btn_search_base },
            { id: "s2_choice_manual", title: t.btn_manual_entry },
            { id: NAV_MENU_ID, title: t.btn_menu },
        ]);
        return;
    }

    const question = FIELD_QUESTIONS[field] || "Введите значение:";
    await setStep(from, "doc_fill");
    await sendNavPrompt(from, question);
}

