async function generateDoc(from) {
    const state = await getUser(from);
    const d = state?.data || {};
    const doc = getDoc(d.doc_key);
    if (!doc) return goToMenuPreserveLang(from);

    const today = new Date().toLocaleDateString("ru-RU");
    const data = {
        ...d,
        current_date: today,
        currentDate: today,
        appealDate: today,
        phone: from,
    };

    if (doc.key === "zayavlenie") {
        data.bailiff_address = d.bailiff_address || d.bailiff_region || "";
        data.bailiff_phone = d.bailiff_phone || "";
        data.bailiff_email = d.bailiff_email || "";
        data.case_date = d.case_date || "";
    }

    if (doc.key === "notary_docs") {
        data.notary_name = d.notary_full_name || d.notary_name || "";
        data.notary_address = d.notary_address || d.notary_region || "";
        data.notary_phone = d.notary_phone || "";
        data.notary_email = d.notary_email || "";
        data.case_date = d.case_date || "";
    }

    if (doc.key === "vozrazhenie") {
        data.notary_name = d.notary_full_name || d.notary_name || "";
        data.debt_amount = d.debt_amount || "";
    }

    if (doc.key === "complaint_chamber" || doc.key === "complaint_court" || doc.key === "complaint_justice") {
        data.notaryName = d.comp_bailiff_name || d.notary_full_name || "";
        data.notaryAddress = d.comp_region || d.bailiff_region || d.bailiff_address || "";
        data.bankName = d.comp_bank || d.bank_name || "";
        data.arrestDate = d.comp_arrest_date || d.case_date || "";
        data.debtorName = d.client_full_name || "";
        data.debtorIIN = d.iin || "";
        data.debtorAddress = d.client_address || "";
        data.debtorPhone = d.client_phone || "";
        if (doc.key === "complaint_court") {
            data.caseNumber = d.case_number || "";
        }
    }

    const payload = {
        template: doc.template,
        data,
        lang: d.lang || "ru",
    };

    try {
        await sendWhatsAppMessage(from, (await getT(from)).processing);
        const gen = await axios.post(DOC_GEN_URL, payload, { timeout: 60000 });
        if (!gen.data?.url) throw new Error("No URL in response");
        await setData(from, "__last_doc_url", gen.data.url);

        await sendWhatsAppDocument(from, gen.data.url, `${doc.key}.pdf`);

        await sendAfterDelivery(from);
        await setStep(from, "after_delivery");
        await setData(from, "doc_key", null);
        await setData(from, "doc_index", null);
        await setData(from, "doc_waiting_notary", false);

        try {
            await sendTelegramMessage(`✅ <b>DOC GENERATED</b>
To: ${from}
Template: ${doc.template}
Link: ${gen.data.url}`);
        } catch (err) { }
    } catch (e) {
        console.error("❌ Generation failed:", e.message);
        try {
            await sendTelegramMessage(`🚨 <b>GEN ERROR</b>
To: ${from}
Error: ${e.message}`);
        } catch (err) { }
        const t = await getT(from);
        await sendWhatsAppMessage(from, "❌ " + (t.error_gen || "Ошибка создания документа."));
    }
}


function buildNotaryResultsBody(page, total) {
    const start = page * NOTARY_PAGE_SIZE + 1;
    const end = Math.min(total, page * NOTARY_PAGE_SIZE + NOTARY_PAGE_SIZE);
    return `Нашёл варианты (${start}–${end} из ${total}). Выберите нотариуса:`;
}

async function resolveNotaryById(id) {
    const fromCsv = notaryDb.getById(id);
    if (fromCsv) return fromCsv;
    try {
        const { getNotaryById } = await import("./db.js");
        const n = getNotaryById(id);
        if (!n) return null;
        return {
            id: String(n.id),
            full_name: n.fio || "",
            region: n.region || "",
            address: n.address || "",
            phone: n.phone || "",
            email: n.email || "",
        };
    } catch (e) {
        return null;
    }
}

async function searchNotariesSafe(query) {
    const q = String(query || "").trim();
    if (!q) return [];
    const fromCsv = notaryDb.search(q, 50);
    if (fromCsv && fromCsv.length) return fromCsv;
    try {
        const { searchNotaries } = await import("./db.js");
        const rows = searchNotaries(q) || [];
        return rows.map(n => ({
            id: String(n.id),
            full_name: n.fio || "",
            region: n.region || "",
            address: n.address || "",
            phone: n.phone || "",
            email: n.email || "",
        }));
    } catch (e) {
        return [];
    }
}

async function sendNotaryResults(from, results, page, t) {
    const total = results.length;
    const pageItems = slicePage(results, page);

    const start = page * NOTARY_PAGE_SIZE + 1;
    const end = Math.min(total, page * NOTARY_PAGE_SIZE + NOTARY_PAGE_SIZE);

    const rows = pageItems.map(n => ({
        id: `notary_pick:${n.id}`,
        title: (n.full_name || "—").slice(0, 24),
        description: (n.region || n.address || "").slice(0, 72),
    }));

    await sendInteractiveList(from, `Нашёл варианты (${start}–${end} из ${total}). Выберите нотариуса:`, `Выбрать ${start}–${end}`, [
        { title: "Нотариусы", rows }
    ]);

    // If there is another page, send its list immediately below
    const nextPage = page + 1;
    if (nextPage * NOTARY_PAGE_SIZE < total) {
        const nextStart = nextPage * NOTARY_PAGE_SIZE + 1;
        const nextEnd = Math.min(total, nextPage * NOTARY_PAGE_SIZE + NOTARY_PAGE_SIZE);
        const nextItems = slicePage(results, nextPage);
        const nextRows = nextItems.map(n => ({
            id: `notary_pick:${n.id}`,
            title: (n.full_name || "—").slice(0, 24),
            description: (n.region || n.address || "").slice(0, 72),
        }));
        await sendInteractiveList(from, `Нашёл варианты (${nextStart}–${nextEnd} из ${total}). Выберите нотариуса:`, `Выбрать ${nextStart}–${nextEnd}`, [
            { title: "Нотариусы", rows: nextRows }
        ]);
    }

    // Actions (3 fixed buttons)
    await sendInteractiveButtons(from, "Действия:", [
        { id: "notary_find", title: "🔎 Новый поиск" },
        { id: "notary_back_pick", title: "◀️ Назад" },
        { id: "nav_menu", title: "🏠 Меню" },
    ]);
}
