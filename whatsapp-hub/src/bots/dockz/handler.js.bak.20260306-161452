                            { id: "notary_back_pick", title: "◀️ Назад" },
                            { id: NAV_MENU_ID, title: t.btn_menu },
                        ]);
                    }
                    return;
                }

                if (text.startsWith("notary_pick:")) {
                    const id = text.split(":")[1];
                    const notary = await resolveNotaryById(id);
                    if (notary) {
                        await setLookupData(from, {
                            selected_notary_id: id,
                            notary_lookup_mode: "confirm",
                        });
                        await sendInteractiveButtons(from, formatNotary(notary), [
                            { id: "notary_confirm_yes", title: "➡️ Продолжить" },
                            { id: "notary_confirm_no", title: "🔁 Выбрать другого" },
                            { id: NAV_MENU_ID, title: t.btn_menu },
                        ]);
                        return;
                    }
                }

                if (text === "notary_confirm_yes") {
                    const docWaiting = d.doc_waiting_notary;
                    const id = d.selected_notary_id;
                    const notary = await resolveNotaryById(id);
                    if (notary) {
                        await setData(from, "notary_id", String(notary.id));
                        await setData(from, "notary_full_name", notary.full_name);
                        await setData(from, "notary_name", notary.full_name);
                        await setData(from, "notary_region", notary.region || "");
                        await setData(from, "notary_address", notary.address || "");
                        await setData(from, "notary_phone", notary.phone || "");
                        await setData(from, "notary_email", notary.email || "");
                        await clearNotaryLookup(from);

                        if (docWaiting) {
                            await setData(from, "doc_waiting_notary", false);
                            const idx = Number(d.doc_index || 0);
                            await setData(from, "doc_index", idx + 1);
                            await setStep(from, "doc_fill");
                            await askDocQuestion(from);
                            return;
                        }

                        await setStep(from, "s2_creditor_name");
                        await sendNavPrompt(from, t.steps_s2[4]);
                        return;
                    }
                }

                if (text === "notary_confirm_no") {
                    const ids = Array.isArray(d.notary_lookup_results) ? d.notary_lookup_results : [];
                    const results = [];
                    for (const id of ids) {
                        const n = await resolveNotaryById(id);
                        if (n) results.push(n);
                    }
                    const page = Number(d.notary_lookup_page || 0) || 0;
                    await setLookupData(from, { notary_lookup_mode: "results" });
                    if (results.length) {
                        await sendNotaryResults(from, results, page, t);
                    } else {
                        await sendInteractiveButtons(from, "Ничего не найдено.", [
                            { id: "notary_find", title: "🔎 Новый поиск" },
                            { id: "notary_back_pick", title: "◀️ Назад" },
                            { id: NAV_MENU_ID, title: t.btn_menu },
                        ]);
                    }
                    return;
                }

                if (mode === "query") {
                    const query = String(text || "").trim();
                    if (!query) {
                        await sendInteractiveButtons(from, "Введите ФИО нотариуса (или часть) для поиска:", [
                            { id: "notary_back_pick", title: "◀️ Назад" },
                            { id: NAV_MENU_ID, title: t.btn_menu },
                        ]);
                        return;
                    }
                    const results = await searchNotariesSafe(query);
                    if (results.length) {
                        const ids = results.map(n => String(n.id));
                        await setLookupData(from, {
                            notary_lookup_mode: "results",
                            notary_lookup_query: query,
                            notary_lookup_results: ids,
                            notary_lookup_page: 0,
                        });
                        await sendNotaryResults(from, results, 0, t);
                        return;
                    }
                    await sendInteractiveButtons(from, "Ничего не найдено. Попробуйте снова.", [
                        { id: "notary_find", title: "🔎 Новый поиск" },
                        { id: "notary_back_pick", title: "◀️ Назад" },
                        { id: NAV_MENU_ID, title: t.btn_menu },
                    ]);
                    return;
                }

                if (mode === "manual") {
                    const name = String(text || "").trim();
                    if (!name) {
                        await sendInteractiveButtons(from, "Введите ФИО нотариуса вручную:", [
                            { id: "notary_back_pick", title: "◀️ Назад" },
                            { id: NAV_MENU_ID, title: t.btn_menu },
                        ]);
                        return;
                    }
                    await setData(from, "notary_full_name", name);
                    await setData(from, "notary_name", name);
                    await clearNotaryLookup(from);
                    if (d.doc_waiting_notary) {
                        await setData(from, "doc_waiting_notary", false);
                        const idx = Number(d.doc_index || 0);
                        await setData(from, "doc_index", idx + 1);
                        await setStep(from, "doc_fill");
                        await askDocQuestion(from);
                        return;
                    }
                    await setStep(from, "s2_notary_address");
                    await sendNavPrompt(from, t.steps_s2[1]);
                    return;
                }

                await sendInteractiveButtons(from, "Шаг 1/11. Как вы хотите указать нотариуса?", [
                    { id: "notary_find", title: "🔎 Найти в базе" },
                    { id: "notary_manual", title: "✍️ Ввести вручную" },
                    { id: NAV_MENU_ID, title: t.btn_menu },
                ]);
                return;
            }

            case "s2_notary_search": {
                await setStep(from, "s2_notary_choice");
                await setLookupData(from, { notary_lookup_mode: "query" });
                await sendInteractiveButtons(from, "Введите ФИО нотариуса (или часть) для поиска:", [
                    { id: "notary_back_pick", title: "◀️ Назад" },
                    { id: NAV_MENU_ID, title: t.btn_menu },
                ]);
                return;
            }

            case "s2_notary_manual_name": {
                await setStep(from, "s2_notary_choice");
                await setLookupData(from, { notary_lookup_mode: "manual" });
                if (text) {
                    await setData(from, "notary_full_name", text);
                    await setData(from, "notary_name", text);
                    await clearNotaryLookup(from);
                    await setStep(from, "s2_notary_address");
                    await sendNavPrompt(from, t.steps_s2[1]);
                } else {
                    await sendInteractiveButtons(from, "Введите ФИО нотариуса вручную:", [
                        { id: "notary_back_pick", title: "◀️ Назад" },
                        { id: NAV_MENU_ID, title: t.btn_menu },
                    ]);
                }
                return;
            }

            case "s2_notary_address":
                await saveAndNext(from, "notary_address", text, "s2_notary_phone", t.steps_s2[2]);
                return;
            case "s2_notary_phone":
                await saveAndNext(from, "notary_phone", text, "s2_notary_email", t.steps_s2[3]);
                return;
            case "s2_notary_email":
                await saveAndNext(from, "notary_email", text, "s2_creditor_name", t.steps_s2[4]);
                return;
            case "s2_creditor_name":
                await saveAndNext(from, "creditor_name", text, "s2_client_full_name", t.steps_s2[5]);
                return;
            case "s2_client_full_name":
                await saveAndNext(from, "client_full_name", text, "s2_client_address", t.steps_s2[6]);
                return;
            case "s2_client_address":
                await saveAndNext(from, "client_address", text, "s2_iin", t.steps_s2[7]);
                return;
            case "s2_iin": {
                if (!isValidIIN(text)) {
                    await sendWhatsAppMessage(from, t.errors.iin);
                    await sendNavPrompt(from, t.steps_s2[7]);
                    return;
                }
                await saveAndNext(from, "iin", text, "s2_client_phone", t.steps_s2[8]);
                return;
            }
            case "s2_client_phone": {
                // Per user request, validation removed.
                // if (!isValidPhone(text)) ...
                await saveAndNext(from, "client_phone", text, "s2_debt_amount", t.steps_s2[9]);
                return;
            }
            case "s2_debt_amount":
                await saveAndNext(from, "debt_amount", text, "s2_client_email", t.steps_s2[10]);
                return;

            case "s2_client_email": {
                if (!isValidEmail(text)) {
                    await sendWhatsAppMessage(from, t.errors.email);
                    await sendNavPrompt(from, t.steps_s2[10]);
                    return;
                }

                await setData(from, "client_email", normalizeOptional(text));

                const current = await getUser(from);
                const tpl = current?.template;

                await sendSummary(from);

                if (tpl === "notary_docs") {
                    await setStep(from, "s3_confirm");
                    return;
                }

                await setStep(from, "s2_confirm");
                return;
            }

            case "s2_confirm":
                await handleConfirmation(from, cleanBox, "vozrazhenie.pdf", t.doc_ready_s2);
                return;

            case "s3_confirm":
                await handleConfirmation(from, cleanBox, "notary_docs.pdf", t.doc_ready_s2);
                return;

            default:
                console.log(`⚠️ Unknown step '${step}' for ${from}. Resetting.`);
                await setStep(from, "main_menu");
                await sendMainMenu(from);
                return;
        }

    } catch (e) {
        console.error(`❌ HANDLER ERROR for ${from}:`, e);
        try {
            await sendTelegramMessage(`🚨 <b>BOT CRASH</b>\n👤 +${from}\n❌ Error: ${e.message}\nStack: ${e.stack ? e.stack.substring(0, 200) : "N/A"}`);
        } catch (tgErr) {
            console.error("TG Send Failed:", tgErr.message);
        }
    }
}
