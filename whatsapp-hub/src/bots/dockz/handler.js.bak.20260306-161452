function getDoc(key) {
    return DOCUMENTS[key] || null;
}

function isNoneValue(v) {
    const s = String(v || "").trim().toLowerCase();
    return s === "нет" || s === "нету" || s === "no" || s === "-";
}

function validateFieldValue(field, value) {
    const rule = FIELD_VALIDATORS[field];
    if (!rule) return { ok: true, value };
    if (rule === "iin") return { ok: isValidIIN(value), value };
    if (rule === "email_optional") {
        if (isNoneValue(value)) return { ok: true, value: "" };
        return { ok: isValidEmail(value), value };
    }
    if (rule === "phone_optional") {
        if (isNoneValue(value)) return { ok: true, value: "" };
        return { ok: true, value };
    }
    return { ok: true, value };
}

